# ============================================
# AgenticRoboticsEvaluator — Environment Template
# ============================================
# Copy this to .env and fill in real values.
# cp .env.example .env

# --- Database ---
POSTGRES_DB=evaluator
POSTGRES_USER=evaluator
POSTGRES_PASSWORD=evaluator_dev

# --- Backend Auth ---
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM (UF Navigator) ---
# Get your key at https://api.ai.it.ufl.edu/ui
# Available models: https://docs.ai.it.ufl.edu/docs/navigator_models/
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.ai.it.ufl.edu/v1/
LLM_MODEL=llama-3.3-70b-instruct
